# Backend chatbot integration (AnythingLLM)
# By default, docker-compose creates a service named 'anythingllm'.

ANYTHINGLLM_BASE_URL=http://anythingllm:3001
ANYTHINGLLM_WORKSPACE_SLUG=intranet-knowledge
# If your AnythingLLM instance requires API key auth, set it here.
ANYTHINGLLM_API_KEY=

# Fast local model settings (Ollama)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:1b
LLM_TIMEOUT_SECONDS=20
ANYTHINGLLM_TIMEOUT_SECONDS=15
OLLAMA_TIMEOUT_SECONDS=18
CHATBOT_CONTEXT_MAX_CHARS=1200
OLLAMA_NUM_CTX=1024
OLLAMA_NUM_PREDICT=180
